#!/usr/bin/env perl

use strict;

use App::lsip;
use Getopt::Long;
use feature 'say';

# Kommandozeilenargumente einlesen
our $quiet     = 0;
our $verbose   = 0;
GetOptions(
    "quiet"       => \$quiet,
    "verbose"     => \$verbose,
) || die("Error in command-line-arguments: $!");

my $counter = 0;
for ((@ARGV)?@ARGV:<STDIN>) {
    chomp;
    my $geoip       = App::lsip::geoip_look_up($_);
    my $dns_reverse = App::lsip::dns_reverse_look_up($_);
    say "$_\t$geoip\t$dns_reverse";
    $counter++;
}

exit !$counter;

