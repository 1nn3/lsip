#!/usr/bin/env perl
# get-credentials [credentials.xml...] >>credentials.tsv
# sort -o credentials.tsv credentials.tsv
# https://metacpan.org/pod/XML::LibXML
# https://metacpan.org/pod/XML::LibXML::NodeList

use feature 'say';

use XML::LibXML;    # libxml-libxml-perl
use XML::LibXML::NodeList;

if ( !@ARGV ) {
    die "No input files!";
}

for (@ARGV) {
    open my $fh, '<', $_ or die "Can't open file: $!";
    binmode $fh;  # drop all PerlIO layers possibly created by a use open pragma
    eval {
        my $dom = XML::LibXML->load_xml( IO => $fh );
        for my $node ( $dom->findnodes('//service')->get_nodelist ) {
            my $address = $node->find('./address/@addr')->to_literal;
            for ( $node->findnodes('.//credentials')->get_nodelist ) {
                my $username = $_->find('./@username')->to_literal;
                my $password = $_->find('./@password')->to_literal;
                say $address, "\t", $username, "\t", $password;
            }
        }
    };
    warn $@ if $@;
}

