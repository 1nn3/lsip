#!/usr/bin/perl

use feature 'say';

use POSIX;
use Socket;

use Getopt::Std;
my %opts;
getopts( 'l', \%opts );

for ((@ARGV)?@ARGV:<>) {

    chomp;

    my $hostname = gethostbyaddr( inet_aton($_), AF_INET );

    if ( !$hostname ) {
        say STDERR "Can't resolve ", $_;
        next;
    }

    if ( $opts{l} ) {
        say $_, "\t", $hostname;
    }
    else {
        say $hostname;
    }

}
