#!/usr/bin/env perl

use Switch;
use Getopt::Long;

my $targets = "targets.txt";
my $output = "resutls";
my $profile;
my $date;
GetOptions(
    "targets=s" => \$targets,
    "profile=s" => \$profile,
    "output=s"  => \$output,
    "date"   => \$date,
) or die("Error in command line arguments");

if ( !-f -r $targets ) {
    warn "No nmap targets file given";
}
else {
    ;
}

if ( !$output ) {
    # output filename
    use File::Basename;
    $output = fileparse( $targets, qr/\.[^.]*/ );
}

if ( $date ) {
    # add date to output filename
    $output .= "-%Y-%m-%d-%T";
}

my @args = (
    "-oA", "$output", "--open", "-T4", "--min-hostgroup", 96, "-Pn", "-iL",
    $targets
);

push @args, @ARGV;

system( "nmap", @args ) == 0
    or die "system Nmap failed: $?";

